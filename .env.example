# -----------------------------------------------------------------------------
# Auth.js / NextAuth (requerido en producción)
# Genera AUTH_SECRET con: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=

# URL pública de la app (producción o Vercel). Opcional en desarrollo local.
AUTH_URL=
# Alias legacy (Auth.js también acepta NEXTAUTH_URL)
NEXTAUTH_URL=

# OAuth Google — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# OAuth GitHub — https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# -----------------------------------------------------------------------------
# OpenRouter (IA — solo servidor; nunca exponer al cliente)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=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

